---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import DocsPrevNext from '../components/DocsPrevNext.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Base title={`${title} — c9watch`} hideNav>
  <div class="docs-shell">
    <Nav />
    <div class="docs-body">
      <DocsSidebar currentPath={currentPath} />
      <div class="docs-scroll">
        <main class="docs-content">
          <slot />
          <DocsPrevNext currentPath={currentPath} />
        </main>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Full viewport shell — prevents body scroll, one scrollbar only */
  .docs-shell {
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
  }

  .docs-body {
    display: flex;
    flex: 1;
    min-height: 0; /* allow flex children to shrink below content size */
  }

  /* Scrollable right panel — scrollbar sits at right viewport edge */
  .docs-scroll {
    flex: 1;
    overflow-y: auto;
  }

  /* Centered content within the scroll panel */
  .docs-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 3rem 4rem;
  }

  .docs-content :global(h1) {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .docs-content :global(h2) {
    font-size: 1.35rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-muted);
    scroll-margin-top: 1rem;
  }

  .docs-content :global(h3) {
    font-size: 1.1rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .docs-content :global(p) {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .docs-content :global(code) {
    background: var(--bg-card);
    padding: 0.15rem 0.4rem;
    font-size: 0.875em;
  }

  .docs-content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .docs-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .docs-content :global(ul), .docs-content :global(ol) {
    color: var(--text-secondary);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .docs-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }

  .docs-content :global(img) {
    border: 1px solid var(--border-default);
    margin: 1rem 0;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  .docs-content :global(th),
  .docs-content :global(td) {
    text-align: left;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border-muted);
    font-size: 14px;
  }

  .docs-content :global(th) {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text-primary);
  }

  .docs-content :global(td) {
    color: var(--text-secondary);
  }

  .docs-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .docs-content {
      padding: 1.5rem 1rem 4rem;
    }
  }
</style>
