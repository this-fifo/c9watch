---
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
}

const { title, description = 'Monitor and control all your Claude Code sessions from one place.', hideNav = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/icon.png" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://c9watch.mclee.dev/og-image.png" />
  <meta property="og:url" content="https://c9watch.mclee.dev" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://c9watch.mclee.dev/og-image.png" />
</head>
<body>
  {!hideNav && <Nav />}
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
