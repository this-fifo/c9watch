---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const pages = [
  { href: '/docs/install', label: 'Install' },
  { href: '/docs/features', label: 'Features' },
  { href: '/docs/how-it-works', label: 'How It Works' },
  { href: '/docs/changelog', label: 'Changelog' },
];

const currentIndex = pages.findIndex(
  p => currentPath === p.href || currentPath === p.href + '/'
);

const prev = currentIndex > 0 ? pages[currentIndex - 1] : null;
const next = currentIndex < pages.length - 1 ? pages[currentIndex + 1] : null;
---

<nav class="docs-prev-next">
  {prev ? (
    <a href={prev.href} class="prev-next-link prev">
      <span class="prev-next-label">Previous</span>
      <span class="prev-next-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5" />
          <path d="M12 19l-7-7 7-7" />
        </svg>
        {prev.label}
      </span>
    </a>
  ) : (
    <div />
  )}
  {next ? (
    <a href={next.href} class="prev-next-link next">
      <span class="prev-next-label">Next</span>
      <span class="prev-next-title">
        {next.label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14" />
          <path d="M12 5l7 7-7 7" />
        </svg>
      </span>
    </a>
  ) : (
    <div />
  )}
</nav>

<style>
  .docs-prev-next {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-muted);
  }

  .prev-next-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--border-default);
    text-decoration: none !important;
    transition: border-color var(--transition-fast);
    width: 200px;
    flex-shrink: 0;
  }

  .prev-next-link:hover {
    border-color: var(--border-focus);
  }

  .prev-next-link.next {
    align-items: flex-end;
    margin-left: auto;
  }

  .prev-next-label {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prev-next-title {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }
</style>
