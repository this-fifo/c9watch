---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const sections = [
  {
    href: '/docs/install',
    label: 'Install',
    subs: [
      { hash: '#quick-install', label: 'Quick install' },
      { hash: '#download-manually', label: 'Download' },
      { hash: '#build-from-source', label: 'Build from source' },
      { hash: '#demo-mode', label: 'Demo mode' },
    ],
  },
  {
    href: '/docs/features',
    label: 'Features',
    subs: [
      { hash: '#real-time-status', label: 'Real-time status' },
      { hash: '#conversation-viewer', label: 'Conversation viewer' },
      { hash: '#tray-popover', label: 'Tray popover' },
      { hash: '#session-history', label: 'Session history' },
      { hash: '#cost-tracker', label: 'Cost tracker' },
    ],
  },
  {
    href: '/docs/how-it-works',
    label: 'How It Works',
    subs: [
      { hash: '#architecture-overview', label: 'Architecture' },
      { hash: '#live-monitoring', label: 'Live monitoring' },
      { hash: '#ide-detection', label: 'IDE detection' },
      { hash: '#session-history', label: 'Session history' },
      { hash: '#cost-tracking', label: 'Cost tracking' },
      { hash: '#tray-popover', label: 'Tray popover' },
      { hash: '#tech-stack', label: 'Tech stack' },
    ],
  },
  {
    href: '/docs/changelog',
    label: 'Changelog',
    subs: [
      { hash: '#040', label: 'v0.4.0' },
      { hash: '#030', label: 'v0.3.0' },
      { hash: '#021', label: 'v0.2.1' },
      { hash: '#020', label: 'v0.2.0' },
      { hash: '#010', label: 'v0.1.0' },
    ],
  },
];

function isActive(sectionHref: string): boolean {
  return currentPath === sectionHref || currentPath === sectionHref + '/';
}
---

<aside class="sidebar" id="docs-sidebar">
  <nav class="sidebar-nav">
    {sections.map(section => (
      <div class="sidebar-section">
        <a
          href={section.href}
          class:list={['sidebar-link', { active: isActive(section.href) }]}
        >
          {section.label}
        </a>
        {section.subs.length > 0 && (
          <div class="sidebar-subs">
            {section.subs.map(sub => (
              <a
                href={section.href + sub.hash}
                class="sidebar-sub"
                data-hash={sub.hash.slice(1)}
              >
                {sub.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>
</aside>

<script>
  // --- Scroll-spy: highlight subsection based on scroll position ---
  const scrollContainer = document.querySelector('.docs-scroll');
  const subLinks = document.querySelectorAll('.sidebar-sub') as NodeListOf<HTMLAnchorElement>;

  if (scrollContainer && subLinks.length > 0) {
    const trackedIds: string[] = [];
    subLinks.forEach(link => {
      const hash = link.getAttribute('data-hash');
      if (hash) trackedIds.push(hash);
    });

    const headings = trackedIds
      .map(id => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    let activeHash = '';

    function updateScrollSpy() {
      if (!scrollContainer) return;

      const offset = 80;
      let currentId = '';

      for (const heading of headings) {
        if (heading.getBoundingClientRect().top - scrollContainer.getBoundingClientRect().top < offset) {
          currentId = heading.id;
        }
      }

      if (currentId !== activeHash) {
        activeHash = currentId;
        subLinks.forEach(link => {
          const hash = link.getAttribute('data-hash');
          link.classList.toggle('active', hash === currentId);
        });
      }
    }

    scrollContainer.addEventListener('scroll', updateScrollSpy, { passive: true });
    updateScrollSpy();
  }
</script>

<style>
  .sidebar {
    position: relative;
    width: 220px;
    flex-shrink: 0;
    border-right: 1px solid var(--border-muted);
    overflow-y: auto;
  }

  .sidebar-nav {
    padding: 1.5rem 1rem 1.5rem 1.5rem;
  }

  .sidebar-section {
    margin-bottom: 0.5rem;
  }

  .sidebar-link {
    display: block;
    padding: 0.4rem 0.75rem;
    color: var(--text-secondary) !important;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none !important;
    border-left: 2px solid transparent;
    transition: color var(--transition-fast);
  }

  .sidebar-link:hover {
    color: var(--text-primary) !important;
  }

  .sidebar-link.active {
    color: var(--text-primary) !important;
    border-left-color: var(--text-primary);
  }

  .sidebar-subs {
    display: flex;
    flex-direction: column;
    margin: 0.15rem 0 0;
  }

  .sidebar :global(.sidebar-sub) {
    display: block;
    padding: 0.2rem 0.75rem 0.2rem 1.25rem;
    color: var(--text-muted) !important;
    font-size: 12px;
    text-decoration: none !important;
    transition: color var(--transition-fast);
    line-height: 1.6;
  }

  .sidebar :global(.sidebar-sub:hover) {
    color: var(--text-secondary) !important;
    text-decoration: none !important;
  }

  .sidebar :global(.sidebar-sub.active) {
    color: var(--text-primary) !important;
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }
  }
</style>
