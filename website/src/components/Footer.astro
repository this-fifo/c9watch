---
// website/src/components/Footer.astro
---

<footer class="footer">
  <div class="footer-links">
    <a href="https://github.com/minchenlee/c9watch/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
    <span class="footer-sep">/</span>
    <a href="https://github.com/minchenlee/c9watch" target="_blank" rel="noopener">GitHub</a>
    <span class="footer-sep">/</span>
    <a href="https://github.com/minchenlee" target="_blank" rel="noopener">@minchenlee</a>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem;
    text-align: center;
    border-top: 1px solid var(--border-muted);
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    font-size: 13px;
  }

  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--text-secondary);
  }

  .footer-sep {
    color: var(--text-muted);
  }
</style>
