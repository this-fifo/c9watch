---
// website/src/components/InstallCTA.astro
---

<section class="cta">
  <h2 class="cta-heading">Get started</h2>
  <div class="cta-install-box">
    <code>curl -fsSL https://raw.githubusercontent.com/minchenlee/c9watch/main/install.sh | bash</code>
    <button class="cta-copy-btn" aria-label="Copy install command">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="9" y="9" width="13" height="13" rx="0" />
        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
      </svg>
    </button>
  </div>
  <a href="https://github.com/minchenlee/c9watch/releases" class="cta-releases" target="_blank" rel="noopener">
    Or download from GitHub Releases
  </a>
</section>

<script>
  const btn = document.querySelector('.cta-copy-btn');
  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText('curl -fsSL https://raw.githubusercontent.com/minchenlee/c9watch/main/install.sh | bash');
    btn.setAttribute('aria-label', 'Copied!');
    setTimeout(() => btn.setAttribute('aria-label', 'Copy install command'), 2000);
  });
</script>

<style>
  .cta {
    position: relative;
    padding: 4rem 2rem;
    text-align: center;
    border-top: 1px solid var(--border-muted);
    /* Radial glow behind the CTA */
    background: radial-gradient(ellipse at 50% 0%, rgba(0, 112, 243, 0.04) 0%, transparent 70%);
  }

  .cta-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .cta-install-box {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    overflow: hidden;
    transition: border-color 0.5s ease, color 0.5s ease, box-shadow 0.5s ease;
  }

  /* Sweeping highlight across the border on hover */
  .cta-install-box::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -100%;
    width: 60%;
    height: calc(100% + 2px);
    background: linear-gradient(90deg,
      transparent,
      rgba(0, 112, 243, 0.25),
      rgba(255, 130, 20, 0.2),
      transparent
    );
    transition: none;
  }

  .cta-install-box:hover {
    border-color: rgba(0, 112, 243, 0.4);
    color: var(--text-primary);
    box-shadow:
      0 0 20px rgba(0, 112, 243, 0.08),
      0 0 60px rgba(0, 112, 243, 0.04);
  }

  .cta-install-box:hover::before {
    animation: sweep 2.5s ease-in-out infinite;
  }

  @keyframes sweep {
    0% { left: -60%; }
    100% { left: 120%; }
  }

  .cta-copy-btn {
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    background: none;
    border: none;
    transition: color var(--transition-fast);
  }

  .cta-copy-btn:hover {
    color: var(--text-primary);
  }

  .cta-releases {
    display: block;
    color: var(--text-muted);
    font-size: 14px;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .cta-releases:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .cta-install-box {
      font-size: 11px;
    }
  }
</style>
